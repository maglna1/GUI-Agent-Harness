# Template images (contain personal UI screenshots)
templates/

# App visual memory — split tracking:
# meta.json (tips, metadata) → TRACKED (permanent project knowledge)
# components/, pages/, *.png, *.jpg → NOT tracked (machine-specific screenshots)
# states.json, transitions.json, components.json → NOT tracked (runtime-generated)
memory/apps/*/components/
memory/apps/*/pages/
memory/apps/*/components.json
memory/apps/*/states.json
memory/apps/*/transitions.json
memory/.session_log.json

# Platform-specific visual memory generated by local GUI runs
memory/*/apps/

# Detection output
detected/

# Python cache
__pycache__/
*.pyc

# Local virtual environments
.venv/
.venv311/
.venv312/
venv/

# macOS
.DS_Store

# Temp files
/tmp/
_legacy/
scripts/test_states.py
archive/memory_backup/

# Auto-generated by activate.py (platform-specific copy)
actions/_actions.yaml

# Runtime state files
skills/gui-report/scripts/.tracker_state.json

# Local benchmark datasets, caches, and experiment outputs
runs/
benchmarks/screenspot_pro/data/
benchmarks/screenspot_pro/*.jsonl
benchmarks/screenspot_pro/*.errors.jsonl
benchmarks/screenspot_pro/RESULTS.md
benchmarks/osworld/cache/
docs/screenspot_*.csv
docs/screenspot_results*.md

# Machine-local app memory generated while running the harness
gui_harness/memory/apps/

# Local build/package artifacts
*.egg-info/
uv.lock
